#!/bin/bash
# Auto-generated by thrum init --runtime codex
export THRUM_ROLE={{.AgentRole}}
export THRUM_MODULE={{.AgentModule}}

# Ensure daemon running
thrum daemon start || true

# Register agent (reuses existing identity if one exists)
thrum quickstart \
  --name "{{.AgentName}}" \
  --role "$THRUM_ROLE" \
  --module "$THRUM_MODULE" \
  --json

# Check inbox
thrum inbox --unread --json
thrum sent --unread --json
# Mark all messages as read: thrum message read --all
