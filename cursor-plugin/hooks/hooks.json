{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "echo 'Run /thrum:prime to load your session context, identity, and any restart snapshots.'"
      }
    ],
    "beforeShellExecution": [
      {
        "type": "command",
        "command": "__PLUGIN_ROOT__/scripts/block-sync-worktree-cd.sh"
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "__PLUGIN_ROOT__/scripts/stop-check-messages.sh",
        "timeout": 15
      }
    ],
    "preCompact": [
      {
        "type": "command",
        "command": "__PLUGIN_ROOT__/scripts/pre-compact-save-context.sh 2>/dev/null || true"
      }
    ],
    "postCompact": [
      {
        "type": "command",
        "command": "__PLUGIN_ROOT__/scripts/post-compact-recover.sh",
        "timeout": 10
      }
    ]
  }
}
