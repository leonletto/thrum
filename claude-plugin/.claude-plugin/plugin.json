{
  "name": "thrum",
  "description": "Git-backed messaging for AI agent coordination across sessions, worktrees, and machines.",
  "version": "0.6.0",
  "author": {
    "name": "Leon Letto",
    "url": "https://github.com/leonletto"
  },
  "repository": "https://github.com/leonletto/thrum",
  "license": "MIT",
  "homepage": "https://leonletto.github.io/thrum",
  "keywords": [
    "messaging",
    "multi-agent",
    "coordination",
    "git-sync"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/block-sync-worktree-cd.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "thrum prime 2>/dev/null || echo 'Thrum not initialized (run: thrum init)'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop-check-messages.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact-save-context.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
