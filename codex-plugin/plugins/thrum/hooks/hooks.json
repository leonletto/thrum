{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [{
          "type": "command",
          "command": "${PLUGIN_ROOT}/scripts/inject-prime-context.sh",
          "statusMessage": "Loading Thrum prime context",
          "timeout": 30
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "${PLUGIN_ROOT}/scripts/block-sync-worktree-cd.sh",
          "timeout": 5
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "${PLUGIN_ROOT}/scripts/stop-check-messages.sh",
          "timeout": 15
        }]
      }
    ]
  }
}
