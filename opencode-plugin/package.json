{
  "name": "opencode-thrum",
  "version": "0.3.2",
  "description": "Thrum multi-agent coordination plugin for Open Code",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "assets"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "thrum",
    "multi-agent",
    "coordination"
  ],
  "author": "Leon Letto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonletto/thrum.git",
    "directory": "opencode-plugin"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@types/node": "^25.5.2",
    "typescript": "^5.3.0"
  }
}
