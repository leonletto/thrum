#!/usr/bin/env bash
#
# tmux-exec — Run commands in isolated tmux sessions.
#
# Abstracts away tmux session management so callers never need to know tmux
# commands. Useful for running CLI tools in a clean environment (no inherited
# env vars, no PID ancestry contamination) and for manual release testing.
#
# Usage:
#   tmux-exec create <name> [--cwd <dir>] [--clean]    Create a named session
#   tmux-exec run <name> [--timeout <sec>] -- <cmd...>  Run a command in a session
#   tmux-exec exec [--cwd <dir>] [--timeout <sec>] -- <cmd...>  One-shot (ephemeral)
#   tmux-exec send <name> [--clear] <keys...>           Send keystrokes to a session
#   tmux-exec capture <name> [--tail <N>]               Capture pane output
#   tmux-exec destroy <name>                            Destroy a named session
#   tmux-exec list                                      List active sessions
#
# Options:
#   --cwd <dir>       Working directory for the session/command
#   --timeout <sec>   Command timeout in seconds (default: 120)
#   --clean           Strip all THRUM_* env vars from the session (for test isolation)
#   --clear           (send) Clear the line before typing (sends C-u first)
#   --tail <N>        (capture) Show only the last N non-blank lines (default: all)
#   --socket <name>   Custom tmux socket (default: tmux-exec)
#
# Examples:
#   # Set up a test environment
#   tmux-exec create test-env --cwd /tmp/thrum-e2e --clean
#   tmux-exec run test-env -- thrum init
#   tmux-exec run test-env -- thrum team --json
#   tmux-exec destroy test-env
#
#   # One-shot isolated command
#   tmux-exec exec --cwd /tmp/test-repo --clean -- thrum status
#
#   # Interactive session (e.g., Claude Code in tmux)
#   tmux-exec send coordinator --clear "/thrum:prime" Enter
#   sleep 25
#   tmux-exec capture coordinator --tail 40
#
set -euo pipefail

SOCKET="${TMUX_EXEC_SOCKET:-tmux-exec}"
TIMEOUT=120
CWD=""
CLEAN=false
POLL_INTERVAL=0.05

# ── Helpers ──────────────────────────────────────────────────────────────────

tmux_cmd() {
  tmux -u -L "$SOCKET" "$@"
}

die() {
  echo "tmux-exec: error: $*" >&2
  exit 1
}

session_exists() {
  tmux_cmd has-session -t "$1" 2>/dev/null
}

# Build an env-cleaning prefix if --clean is set
clean_prefix() {
  if $CLEAN; then
    # Safe: only unsets THRUM_* vars from the current env, no user input involved
    echo 'for __v in $(env | grep "^THRUM_" | cut -d= -f1); do unset "$__v"; done;'
  fi
}

# Strip tmux capture artifacts from output
clean_output() {
  # Remove "Pane is dead (...)" footer, then trim trailing blank lines
  grep -v '^Pane is dead' | awk '
    { lines[NR] = $0; last = NR }
    END {
      # Find last non-blank line
      while (last > 0 && lines[last] ~ /^[[:space:]]*$/) last--
      for (i = 1; i <= last; i++) print lines[i]
    }
  '
}

# Persistent shared pool session for `cmd_exec`. One PTY per socket
# instead of one PTY per call. Replaces the previous per-call
# new-session + respawn-pane pattern that exhausted macOS's PTY pool
# after ~30-50 rapid invocations (ENXIO "Device not configured").
#
# Concurrent invocations of `tmux-exec exec` from different processes
# share this pane via a flock on the lockfile, so send-keys input
# never interleaves and per-call markers stay attributable.
pool_session_name() {
  echo "tmux-exec-pool-${USER:-default}"
}

pool_lockfile() {
  echo "/tmp/tmux-exec-pool-${SOCKET}-${USER:-default}.lock"
}

# Lazily create the persistent pool session. Spawns
# `bash --noprofile --norc` so prompts/aliases don't clutter
# scrollback or interfere with marker matching.
ensure_pool_session() {
  local pool
  pool=$(pool_session_name)
  if session_exists "$pool"; then
    return 0
  fi
  tmux_cmd new-session -d -s "$pool" bash --noprofile --norc
  # Suppress prompt so marker echoes land on their own line.
  tmux_cmd send-keys -t "$pool" "PS1=''; PROMPT_COMMAND=''" Enter
}

# send_marker_wait <session> <line> <timeout> <outfile>
#
# Sends one composite line to <session> via send-keys, polls the
# captured pane for `^<marker>:<exit-code>$`, and returns the matched
# exit code via stdout. Caller is responsible for the marker (so it
# can include it in <line>) and for reading <outfile>.
#
# Returns the command's exit code as the function's stdout (printf).
# Function's own exit is 0 on marker match, 1 on timeout.
send_marker_wait() {
  local session="$1" line="$2" timeout="$3" marker="$4"
  tmux_cmd send-keys -t "$session" "$line" Enter
  local deadline=$(( $(date +%s) + timeout ))
  local rc=""
  while [[ $(date +%s) -lt $deadline ]]; do
    local pane
    pane=$(tmux_cmd capture-pane -p -J -t "$session" -S - 2>/dev/null || echo "")
    if grep -qE "^${marker}:[0-9]+$" <<<"$pane"; then
      rc=$(grep -E "^${marker}:[0-9]+$" <<<"$pane" | tail -1 | cut -d: -f2)
      break
    fi
    sleep "$POLL_INTERVAL"
  done
  if [[ -z "$rc" ]]; then
    return 1
  fi
  printf '%s' "$rc"
  return 0
}

# Generate a per-call marker token. Embeds $$ + epoch + RANDOM so
# concurrent invocations never collide.
gen_marker() {
  echo "__TMUX_EXEC_DONE_$$_$(date +%s)_${RANDOM}__"
}

gen_outfile() {
  echo "/tmp/tmux-exec-$$-$(date +%s)-${RANDOM}.out"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_create() {
  local name="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cwd)    CWD="$2"; shift 2 ;;
      --clean)  CLEAN=true; shift ;;
      --socket) SOCKET="$2"; shift 2 ;;
      *)        die "create: unknown option: $1" ;;
    esac
  done

  if session_exists "$name"; then
    die "session '$name' already exists (use 'destroy' first)"
  fi

  local args=(new-session -d -s "$name")
  [[ -n "$CWD" ]] && args+=(-c "$CWD")
  tmux_cmd "${args[@]}"

  # If --clean, remove THRUM_* vars from the tmux global environment.
  # Vars live in the global table (inherited from the server's parent process).
  # Session-level -u only hides session overrides, not global ones.
  # Using -gu (global unset) removes them for all new panes in all sessions
  # on this socket — which is fine since each test gets its own socket or
  # all sessions on this socket want clean THRUM_* state.
  if $CLEAN; then
    local var
    while IFS= read -r var; do
      tmux_cmd set-environment -gu "$var"
    done < <(tmux_cmd show-environment -g 2>/dev/null | grep '^THRUM_' | cut -d= -f1)
  fi

  echo "Session '$name' created"
  [[ -n "$CWD" ]] && echo "  cwd: $CWD"
  $CLEAN && echo "  env: THRUM_* vars stripped"
}

cmd_run() {
  local name="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) TIMEOUT="$2"; shift 2 ;;
      --socket)  SOCKET="$2"; shift 2 ;;
      --)        shift; break ;;
      *)         die "run: unknown option '$1' (put command after --)" ;;
    esac
  done

  [[ $# -eq 0 ]] && die "run: no command specified (use -- before command)"

  if ! session_exists "$name"; then
    die "session '$name' does not exist (use 'create' first)"
  fi

  # Build the command string, preserving quoting for each argument.
  local cmd
  cmd=$(printf '%q ' "$@")

  # Inherit the session's start directory so the cmd runs in the same
  # cwd a respawn-pane new-window would have. Wrap in a subshell so
  # the `cd` plus any env mutations the cmd makes scope to that
  # subshell — the user's persistent session shell is untouched.
  local session_cwd
  session_cwd=$(tmux_cmd display-message -p -t "$name" '#{session_path}' 2>/dev/null || echo "")

  local marker outfile cwd_part line rc
  marker=$(gen_marker)
  outfile=$(gen_outfile)
  : >"$outfile"  # ensure readable on early failure paths
  cwd_part=""
  [[ -n "$session_cwd" ]] && cwd_part="cd $(printf %q "$session_cwd") && "
  line="${cwd_part}(${cmd}) > ${outfile} 2>&1; echo \"${marker}:\$?\""

  if rc=$(send_marker_wait "$name" "$line" "$TIMEOUT" "$marker"); then
    if [[ -f "$outfile" ]]; then
      cat "$outfile"
      rm -f "$outfile"
    fi
    return "${rc:-0}"
  fi
  if [[ -f "$outfile" ]]; then
    cat "$outfile" >&2
    rm -f "$outfile"
  fi
  die "command timed out after ${TIMEOUT}s"
}

# shell-run sends a command into the pane's persistent login shell (via
# send-keys), rather than spawning a fresh sh -c subshell like `run` does.
# This is required on macOS for peercred-authenticated thrum calls: fresh
# subshells are resolved as anonymous callers, while commands typed into the
# pane's long-lived shell inherit its CWD/process-tree identity.
#
# Output capture: the command's stdout+stderr are redirected to a temp file
# on the host running tmux, and a marker line with the exit code is echoed
# after. The poller greps the pane for the marker, then cats the temp file
# back to the caller's stdout.
cmd_shell_run() {
  local name="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) TIMEOUT="$2"; shift 2 ;;
      --socket)  SOCKET="$2"; shift 2 ;;
      --)        shift; break ;;
      *)         die "shell-run: unknown option '$1' (put command after --)" ;;
    esac
  done

  [[ $# -eq 0 ]] && die "shell-run: no command specified (use -- before command)"

  if ! session_exists "$name"; then
    die "session '$name' does not exist (use 'create' first)"
  fi

  local cmd
  cmd=$(printf '%q ' "$@")

  local marker="__TMUX_EXEC_DONE_${RANDOM}_$(date +%s)__"
  local outfile="/tmp/tmux-exec-$$-$(date +%s)-$RANDOM.out"

  local line="${cmd}> ${outfile} 2>&1; echo \"${marker}:\$?\""

  tmux_cmd send-keys -t "$name" "$line" Enter

  local deadline=$(( $(date +%s) + TIMEOUT ))
  local rc=""
  while [[ $(date +%s) -lt $deadline ]]; do
    local pane
    pane=$(tmux_cmd capture-pane -p -t "$name" -S - 2>/dev/null || echo "")
    if grep -qE "^${marker}:[0-9]+$" <<<"$pane"; then
      rc=$(grep -E "^${marker}:[0-9]+$" <<<"$pane" | tail -1 | cut -d: -f2)
      break
    fi
    sleep "$POLL_INTERVAL"
  done

  if [[ -z "$rc" ]]; then
    if [[ -f "$outfile" ]]; then
      cat "$outfile" >&2
      rm -f "$outfile"
    fi
    die "shell-run: command timed out after ${TIMEOUT}s (marker not seen)"
  fi

  if [[ -f "$outfile" ]]; then
    cat "$outfile"
    rm -f "$outfile"
  fi

  return "$rc"
}

cmd_exec() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cwd)     CWD="$2"; shift 2 ;;
      --timeout) TIMEOUT="$2"; shift 2 ;;
      --clean)   CLEAN=true; shift ;;
      --socket)  SOCKET="$2"; shift 2 ;;
      --)        shift; break ;;
      *)         die "exec: unknown option '$1' (put command after --)" ;;
    esac
  done

  [[ $# -eq 0 ]] && die "exec: no command specified (use -- before command)"

  # Build the command string, preserving quoting for each argument.
  local cmd
  cmd=$(printf '%q ' "$@")

  # Pool-session pattern: route this one-shot through the per-socket
  # persistent pool pane. Caller still gets ephemeral semantics
  # (cwd / env / cleanup all subshell-scoped), but only one PTY is
  # allocated for the lifetime of the socket — sidestepping the
  # macOS PTY-pool exhaustion that respawn-pane churn causes.
  #
  # Concurrent script invocations serialize on a flock so send-keys
  # never interleaves and per-call markers stay attributable.
  local lock pool
  lock=$(pool_lockfile)
  pool=$(pool_session_name)

  # shellcheck disable=SC2094
  builtin exec 9>"$lock"
  if command -v flock >/dev/null 2>&1; then
    flock -w "$TIMEOUT" 9 || die "exec: could not acquire pool lock within ${TIMEOUT}s"
  fi
  ensure_pool_session

  local marker outfile cwd_part prefix line rc
  marker=$(gen_marker)
  outfile=$(gen_outfile)
  : >"$outfile"
  cwd_part=""
  [[ -n "$CWD" ]] && cwd_part="cd $(printf %q "$CWD") && "
  prefix=$(clean_prefix)
  # Wrap cmd + env-cleanup in a subshell so cwd / unset side-effects
  # don't leak into the persistent pool shell.
  line="(${cwd_part}${prefix}${cmd}) > ${outfile} 2>&1; echo \"${marker}:\$?\""

  if rc=$(send_marker_wait "$pool" "$line" "$TIMEOUT" "$marker"); then
    builtin exec 9>&-
    if [[ -f "$outfile" ]]; then
      cat "$outfile"
      rm -f "$outfile"
    fi
    return "${rc:-0}"
  fi
  builtin exec 9>&-
  if [[ -f "$outfile" ]]; then
    cat "$outfile" >&2
    rm -f "$outfile"
  fi
  die "command timed out after ${TIMEOUT}s"
}

cmd_send() {
  local name="$1"
  shift

  local clear=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --clear)  clear=true; shift ;;
      --socket) SOCKET="$2"; shift 2 ;;
      --)       shift; break ;;
      *)        break ;;
    esac
  done

  [[ $# -eq 0 ]] && die "send: no keys specified"

  if ! session_exists "$name"; then
    die "session '$name' does not exist"
  fi

  # Clear line first if requested
  if $clear; then
    tmux_cmd send-keys -t "$name" C-u
  fi

  # Send each argument as a separate send-keys call.
  # This lets callers pass "Enter", "C-c", etc. as separate args.
  for key in "$@"; do
    tmux_cmd send-keys -t "$name" "$key"
  done
}

cmd_capture() {
  local name="$1"
  shift

  local tail_n=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)   tail_n="$2"; shift 2 ;;
      --socket) SOCKET="$2"; shift 2 ;;
      *)        die "capture: unknown option: $1" ;;
    esac
  done

  if ! session_exists "$name"; then
    die "session '$name' does not exist"
  fi

  local output
  output=$(tmux_cmd capture-pane -p -t "$name" -S - -E - 2>/dev/null || echo "")

  # For live sessions, keep all lines (including blanks) — only strip trailing
  # empty lines from the tmux pane buffer. No awk 'NF' — that destroys
  # terminal output structure.
  if [[ -n "$tail_n" ]]; then
    echo "$output" | grep -v '^$' | tail -n "$tail_n"
  else
    echo "$output" | clean_output
  fi
}

cmd_destroy() {
  local name="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --socket) SOCKET="$2"; shift 2 ;;
      *)        die "destroy: unknown option: $1" ;;
    esac
  done

  if ! session_exists "$name"; then
    echo "Session '$name' does not exist (already destroyed?)"
    return 0
  fi

  tmux_cmd kill-session -t "$name"
  echo "Session '$name' destroyed"
}

cmd_list() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --socket) SOCKET="$2"; shift 2 ;;
      *)        die "list: unknown option: $1" ;;
    esac
  done

  tmux_cmd list-sessions -F '#{session_name}  (#{session_windows} windows, created #{session_created_string})' 2>/dev/null || echo "(no active sessions)"
}

# ── Main ─────────────────────────────────────────────────────────────────────

usage() {
  # Extract header comment block as usage text (macOS sed compatible)
  awk 'NR>=3 && /^#/{sub(/^# ?/,""); print; next} NR>=3{exit}' "$0"
  exit "${1:-0}"
}

[[ $# -eq 0 ]] && usage 1

case "$1" in
  create)    shift; cmd_create "$@" ;;
  run)       shift; cmd_run "$@" ;;
  shell-run) shift; cmd_shell_run "$@" ;;
  exec)      shift; cmd_exec "$@" ;;
  send)      shift; cmd_send "$@" ;;
  capture)   shift; cmd_capture "$@" ;;
  destroy)   shift; cmd_destroy "$@" ;;
  list)      shift; cmd_list "$@" ;;
  -h|--help|help) usage 0 ;;
  *)         die "unknown command: $1 (try 'tmux-exec help')" ;;
esac
